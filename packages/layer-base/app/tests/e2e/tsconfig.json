{
  "compilerOptions": {
    "target": "ES2021",
    "lib": [
      "ES2021",
      "DOM"
    ],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@layer-base/e2e/*": [
        "./*"
      ]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
  },
  "include": [
    "**/*"
  ]
}
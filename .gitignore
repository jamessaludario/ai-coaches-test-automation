# Ignore node modules
node_modules/

# Ignore authentication state files
e2e/.auth/
packages/layer-base/app/tests/.auth/
*.auth-*.json

# Ignore Playwright test results
test-results/
playwright-report/
playwright/.cache/

# Ignore environment files (if they contain secrets)
# .env
# .env.local
# .env.*.local

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore build artifacts
dist/
build/
.output/
.nuxt/

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore package manager lock files (if using multiple package managers)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
